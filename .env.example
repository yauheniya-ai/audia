# ─────────────────────────────────────────────────────────────────
#  audia – example environment configuration
#
#  Copy this file to .env and fill in your values:
#    cp .env.example .env
#
#  All variables use the AUDIA_ prefix.
#  Variables without a prefix override are the standard pydantic-settings
#  auto-mapping: AUDIA_<FIELD_NAME> (case-insensitive).
# ─────────────────────────────────────────────────────────────────


# ─────────────────────────── LLM  (REQUIRED)
# LLM curation is the core of audia – choosing math→English rewriting,
# table summarisation, citation removal, and acknowledgements condensing.
#
# Pick one provider:

# Option A – OpenAI (recommended for quality)
AUDIA_LLM_PROVIDER=openai
AUDIA_OPENAI_API_KEY=sk-...
AUDIA_LLM_MODEL=gpt-5.4-nano         

# Option B – Anthropic Claude
# AUDIA_LLM_PROVIDER=anthropic
# AUDIA_ANTHROPIC_API_KEY=sk-ant-...
# AUDIA_LLM_MODEL=claude-3-5-haiku-20241022   # or claude-3-5-sonnet-20241022

# LLM curation chunk size (characters). Larger = fewer API calls, higher cost.
# AUDIA_LLM_MAX_CHUNK_CHARS=8000

# LLM temperature (0 = deterministic, 1 = creative)
# AUDIA_LLM_TEMPERATURE=0.1


# ─────────────────────────── TTS  (text-to-speech)
# Default: edge-tts – free, no API key, requires internet.
# AUDIA_TTS_BACKEND=edge-tts

# edge-tts voice name. Browse all voices:  edge-tts --list-voices
# AUDIA_TTS_VOICE=en-US-AriaNeural        # female, US English
# AUDIA_TTS_VOICE=en-US-GuyNeural         # male,   US English
# AUDIA_TTS_VOICE=en-GB-SoniaNeural       # female, British English
# AUDIA_TTS_VOICE=en-GB-RyanNeural        # male,   British English
# AUDIA_TTS_VOICE=en-AU-NatashaNeural     # female, Australian English

# Speaking rate offset for edge-tts
# AUDIA_TTS_RATE=+0%                      # +10% = 10% faster, -10% = slower

# Characters per TTS chunk. Larger = fewer file joins but may time out.
# AUDIA_TTS_CHUNK_CHARS=3800

# ─── Kokoro TTS (local, no internet, GPU optional)
# Requires:  pip install audia[kokoro]
# AUDIA_TTS_BACKEND=kokoro
# AUDIA_TTS_VOICE=af_heart                # see kokoro docs for all voices

# ─── OpenAI TTS (high quality, costs money)
# AUDIA_TTS_BACKEND=openai
# AUDIA_TTS_VOICE=nova                    # alloy | echo | nova | shimmer | onyx | fable


# ─────────────────────────── STT  (speech-to-text input)
# Requires:  pip install audia[stt]
# AUDIA_STT_MODEL=base                    # tiny | base | small | medium | large-v3
# AUDIA_STT_DEVICE=cpu                    # cpu | cuda
# AUDIA_STT_RECORD_SECONDS=30             # max microphone recording duration


# ─────────────────────────── Storage
# Where audia stores the SQLite database, uploaded PDFs, and audio output.
# AUDIA_DATA_DIR=~/.audia


# ─────────────────────────── Web UI server
# AUDIA_SERVER_HOST=127.0.0.1
# AUDIA_SERVER_PORT=8000
# AUDIA_RELOAD=false                      # set true for development


# ─────────────────────────── Research
# Max papers returned per ArXiv query
# AUDIA_ARXIV_MAX_RESULTS=10
